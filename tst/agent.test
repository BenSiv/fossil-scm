###############################################################################

set body [subst {sid=$lastSid&acid=6&feedback=useful&proof=$proof}]
set response [agent_http_request $repository POST /agent-feedback $body]
set RESULT [agent_http_body $response]
set CODE 0
test agent-feedback-1 {[agent_http_status $response] eq {200}}
test agent-feedback-2 {[string first {"acid":6} $RESULT]>=0}
test agent-feedback-3 {[string first {"feedback":"useful"} $RESULT]>=0}

fossil sql "SELECT user_feedback FROM ai_chat_eval ORDER BY eval_id DESC LIMIT 1"
test agent-feedback-4 {[normalize_result] eq {useful}}

set response [agent_http_request $repository GET [subst {/agent-history?sid=$lastSid}] {}]
set RESULT [agent_http_body $response]
set CODE 0
