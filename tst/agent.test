############################################################################
#
# Hermetic agent regression tests.
#

require_no_open_checkout

set path [file dirname [info script]]
set backend [file normalize [file join $path fake-agent-backend.sh]]

proc agent_http_request {repository method url body} {
  set requestFile [file join [pwd] agent-http-[getSeqNo].txt]
  set outFile [file join [pwd] agent-http-out-[getSeqNo].txt]
  if {$method eq "POST"} {
    set len [string length $body]
    write_file $requestFile [subst {POST $url HTTP/1.0\r
Host: localhost\r
User-Agent: Fossil-Agent-Test\r
Content-Type: application/x-www-form-urlencoded\r
Content-Length: $len\r
\r
$body}]
  } else {
    write_file $requestFile [subst {GET $url HTTP/1.0\r
Host: localhost\r
User-Agent: Fossil-Agent-Test\r
\r
}]
  }
  fossil http --in $requestFile --out $outFile --ipaddr 127.0.0.1 \
      $repository --localauth -expectError
  set result [expr {[file exists $outFile] ? [read_file $outFile] : ""}]
  catch {file delete $requestFile}
  catch {file delete $outFile}
  return $result
}

proc agent_http_status {response} {
  set status ""
  set response [string map [list \r\n \n] $response]
  regexp {^HTTP/\S+\s+([0-9][0-9][0-9])} $response dummy status
  return $status
}

proc agent_http_body {response} {
  set response [string map [list \r\n \n] $response]
  set sep [string first "\n\n" $response]
  if {$sep<0} {
    return ""
  }
  return [string range $response [expr {$sep+2}] end]
}

test_setup

fossil test-th-eval --open-config {repository}
set repository [normalize_result]
if {[string length $repository] == 0} {
  puts "Detection of the open repository file failed."
  test_cleanup_then_return
}

set cfgDir [file normalize [file join [pwd] agent-config]]
set userCfgRoot [file normalize [file join [pwd] xdg]]
set userCfgDir [file join $userCfgRoot fossil]
file mkdir $cfgDir
file mkdir $userCfgDir

write_file [file join $cfgDir agent.json] [subst -nocommands {
{
  "provider": "codex",
  "model": "test-chat-model",
  "command": "$backend",
  "embedding_provider": "ollama",
  "embedding_model": "test-embed-model",
  "embedding_command": "$backend"
}
}]

write_file [file join $userCfgDir ai-agent.json] [subst -nocommands {
{
  "model": "user-config-model",
  "command": "$backend",
  "embedding_model": "user-embed-model",
  "embedding_command": "$backend"
}
}]

###############################################################################

fossil ai init

write_file agent-note.txt "Embeddings let retrieval find this note.\n"
fossil agent --agent-config [file join $cfgDir agent.json] note agent-note.txt --title "Embeddings Note"
test agent-note-1 {[normalize_result] eq {Added note: Embeddings Note}}

fossil sql "SELECT count(*) FROM ai_note WHERE title='Embeddings Note'"
test agent-note-2 {[normalize_result] eq {1}}

###############################################################################

fossil agent --agent-config [file join $cfgDir agent.json] embed {probe text}
test agent-embed-1 {[normalize_result] eq {0.125000, 0.250000, 0.500000, 1.000000}}

fossil agent --agent-config [file join $cfgDir agent.json] semantic-index
test agent-index-1 {[normalize_result] eq {Indexed 1 notes.}}

fossil sql "SELECT source_type || '|' || dim FROM ai_vector ORDER BY source_id DESC LIMIT 1"
test agent-index-2 {[normalize_result] eq {note|4}}

fossil agent --agent-config [file join $cfgDir agent.json] retrieve {Embeddings retrieval note} --limit 3
test agent-retrieve-1 {[string first {Embeddings Note} [normalize_result]]>=0}
test agent-retrieve-2 {[string first {reinforcement: +} [normalize_result]]>=0}

###############################################################################

set RESULT [exec env XDG_CONFIG_HOME=$userCfgRoot $::fossilexe agent embed {user config probe}]
set CODE 0
test agent-config-user-1 {[normalize_result] eq {0.125000, 0.250000, 0.500000, 1.000000}}

fossil set agent-config-path [file join $cfgDir agent.json]
fossil test-th-eval {set out [proc_verify_csrf]; set out}
set proof [normalize_result]

###############################################################################

set response [agent_http_request $repository GET /agentui {}]
set RESULT $response
set CODE 0
test agent-ui-1 {[agent_http_status $RESULT] eq {200}}
test agent-ui-2 {[string first {id="agent-config-source"} $RESULT]>=0 && [string first [subst {repo agent-config-path: [file join $cfgDir agent.json]}] $RESULT]>=0}
test agent-ui-3 {[string first {id="agent-config-chat-provider"} $RESULT]>=0 && [string first {>codex<} $RESULT]>=0}
test agent-ui-4 {[string first {id="agent-config-chat-model"} $RESULT]>=0 && [string first {>test-chat-model<} $RESULT]>=0}
test agent-ui-5 {[string first {id="agent-config-embedding-provider"} $RESULT]>=0 && [string first {>ollama<} $RESULT]>=0}
test agent-ui-6 {[string first {id="agent-config-embedding-model"} $RESULT]>=0 && [string first {>test-embed-model<} $RESULT]>=0}
test agent-ui-7 {[string first {id="agent-config-capabilities"} $RESULT]>=0 && [string first {chat streaming=no, model discovery=no, provider locked=yes, embeddings=yes} $RESULT]>=0}
test agent-ui-8 {[string first {id="agent-model-suggestions"} $RESULT]>=0}
test agent-ui-9 {[string first {<option value="codex" selected>} $RESULT]>=0}
test agent-ui-10 {[string first {<select id="agent-provider" disabled>} $RESULT]>=0}

###############################################################################

set response [agent_http_request $repository GET /agent-config {}]
set RESULT [agent_http_body $response]
set CODE 0
test agent-config-1 {[agent_http_status $response] eq {200}}
test agent-config-2 {[string first {"chat_provider":"codex"} $RESULT]>=0}
test agent-config-3 {[string first {"chat_model":"test-chat-model"} $RESULT]>=0}
test agent-config-4 {[string first {"embedding_provider":"ollama"} $RESULT]>=0}
test agent-config-5 {[string first {"embedding_model":"test-embed-model"} $RESULT]>=0}
test agent-config-6 {[string first {"chat_provider_locked":1} $RESULT]>=0}
test agent-config-7 {[string first {"chat_supports_streaming":0} $RESULT]>=0}
test agent-config-8 {[string first {"chat_supports_model_discovery":0} $RESULT]>=0}
test agent-config-9 {[string first {"embedding_available":1} $RESULT]>=0}
test agent-config-10 {[string first {"chat_provider_known":1} $RESULT]>=0}
test agent-config-11 {[string first {"embedding_provider_known":1} $RESULT]>=0}
test agent-config-12 {[string first {"chat_provider_choices":["codex","ollama","custom"]} $RESULT]>=0}
test agent-config-13 {[string first {"chat_model_suggestions":["auto"]} $RESULT]>=0}

###############################################################################

set body [subst {sid=0&msg=say+only+hi&model=test-chat-model&context=1&proof=$proof}]
set response [agent_http_request $repository POST /agent-chat $body]
set RESULT $response
set CODE 0
test agent-chat-1 {[agent_http_status $RESULT] eq {200}}
test agent-chat-2 {[string first {"sid":} [agent_http_body $RESULT]]>=0}
test agent-chat-3 {[string first {"model":"test-chat-model"} [agent_http_body $RESULT]]>=0}
test agent-chat-4 {[string first {test-agent model=test-chat-model} [agent_http_body $RESULT]]>=0}

fossil sql "SELECT count(*) FROM agentchat"
test agent-chat-5 {[normalize_result] eq {2}}

fossil sql "SELECT title FROM agentchat_session ORDER BY sid DESC LIMIT 1"
test agent-chat-6 {[normalize_result] eq {say only hi}}

fossil sql "SELECT msg FROM agentchat WHERE role='agent' ORDER BY acid DESC LIMIT 1"
test agent-chat-7 {[string first {reply:} [normalize_result]]>=0}

fossil sql "SELECT provider || '|' || model FROM agentchat_session ORDER BY sid DESC LIMIT 1"
test agent-chat-8 {[normalize_result] eq {codex|test-chat-model}}

fossil sql "SELECT group_concat(rk, ',') FROM (SELECT role || '|' || kind AS rk FROM agentchat ORDER BY acid)"
test agent-chat-9 {[normalize_result] eq {user|prompt,agent|reply}}

fossil sql "SELECT sid FROM agentchat_session ORDER BY sid DESC LIMIT 1"
set lastSid [normalize_result]
set response [agent_http_request $repository GET [subst {/agentui?sid=$lastSid}] {}]
set RESULT $response
set CODE 0
test agent-chat-10 {[agent_http_status $RESULT] eq {200}}
test agent-chat-11 {[string first {value="codex"} $RESULT]>=0}
test agent-chat-12 {[string first {value="test-chat-model"} $RESULT]>=0}
test agent-chat-13 {[string first {{reply}} $RESULT]>=0}

set response [agent_http_request $repository GET [subst {/agent-config?sid=$lastSid}] {}]
set RESULT [agent_http_body $response]
set CODE 0
test agent-chat-14 {[agent_http_status $response] eq {200}}
test agent-chat-15 {[string first {"chat_provider":"codex"} $RESULT]>=0}
test agent-chat-16 {[string first {"chat_model":"test-chat-model"} $RESULT]>=0}

set response [agent_http_request $repository GET [subst {/agent-history?sid=$lastSid}] {}]
set RESULT [agent_http_body $response]
set CODE 0
test agent-chat-17 {[agent_http_status $response] eq {200}}
test agent-chat-18 {[string first {"sid":} $RESULT]>=0}
test agent-chat-19 {[string first {"title":"say only hi"} $RESULT]>=0}
test agent-chat-20 {[string first {"provider":"codex"} $RESULT]>=0}
test agent-chat-21 {[string first {"model":"test-chat-model"} $RESULT]>=0}
test agent-chat-22 {[string first {"messages":[} $RESULT]>=0}
test agent-chat-23 {[string first {"role":"user","kind":"prompt"} $RESULT]>=0}
test agent-chat-24 {[string first {"role":"agent","kind":"reply"} $RESULT]>=0}

###############################################################################

set body [subst {sid=0&msg=say+only+hi&model=qwen3.5%3A0.8b&context=0&proof=$proof}]
set response [agent_http_request $repository POST /agent-chat $body]
set RESULT [agent_http_body $response]
set CODE 0
test agent-chat-mismatch-1 {[string first {looks like an Ollama model but provider is codex} $RESULT]>=0}
fossil sql "SELECT count(*) FROM agentchat"
test agent-chat-mismatch-2 {[normalize_result] eq {2}}

###############################################################################

test_cleanup
