set response [agent_http_request $repository GET [subst {/agent-events?sid=$lastSid&after=5}] {}]
set RESULT [agent_http_body $response]
set CODE 0
test agent-feedback-6 {[string first {"acid":6,"role":"agent","kind":"reply"} $RESULT]>=0}
test agent-feedback-7 {[string first {"feedback":"useful"} $RESULT]>=0}

fossil agent eval-report
test agent-feedback-8 {[string first {codex|test-chat-model|final|ok|none|useful|1} [normalize_result]]>=0}

###############################################################################

set body [subst {sid=0&msg=say+only+hi&model=qwen3.5%3A0.8b&context=0&proof=$proof}]
set response [agent_http_request $repository POST /agent-chat $body]
set RESULT [agent_http_body $response]
set CODE 0
test agent-chat-mismatch-1 {[string first {looks like an Ollama model but provider is codex} $RESULT]>=0}
fossil sql "SELECT count(*) FROM agentchat"
test agent-chat-mismatch-2 {[normalize_result] eq {6}}
fossil sql "SELECT count(*) FROM ai_chat_eval"
test agent-chat-mismatch-3 {[normalize_result] eq {1}}

