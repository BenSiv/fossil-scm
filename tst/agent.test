fossil sql "SELECT reply_kind || '|' || quality_status || '|' || reasoning_status FROM ai_chat_eval ORDER BY eval_id DESC LIMIT 1"
test agent-chat-8b {[normalize_result] eq {final|ok|none}}

fossil sql "SELECT group_concat(rk, ',') FROM (SELECT role || '|' || kind AS rk FROM agentchat ORDER BY acid)"
test agent-chat-9 {[normalize_result] eq {system|progress,system|tool,system|progress,user|prompt,system|progress,agent|reply}}

fossil sql "SELECT meta FROM agentchat WHERE role='system' ORDER BY acid ASC LIMIT 1"
test agent-chat-10 {[normalize_result] eq {{"stage":"context","enabled":true}}}

fossil sql "SELECT meta FROM agentchat WHERE role='system' AND kind='tool' ORDER BY acid ASC LIMIT 1"
test agent-chat-11 {[normalize_result] eq {{"tool":"chat-backend","provider":"codex"}}}

fossil sql "SELECT meta FROM agentchat WHERE role='system' AND kind='progress' ORDER BY acid ASC LIMIT 1 OFFSET 1"
test agent-chat-12 {[normalize_result] eq {{"stage":"backend","status":"running"}}}

fossil sql "SELECT meta FROM agentchat WHERE role='system' AND kind='progress' ORDER BY acid DESC LIMIT 1"
test agent-chat-13 {[normalize_result] eq {{"stage":"backend","status":"ok"}}}

fossil sql "SELECT meta FROM agentchat WHERE role='user' ORDER BY acid ASC LIMIT 1"
test agent-chat-14 {[normalize_result] eq {{"context":true}}}

fossil sql "SELECT sid FROM agentchat_session ORDER BY sid DESC LIMIT 1"
set lastSid [normalize_result]
set response [agent_http_request $repository GET [subst {/agentui?sid=$lastSid}] {}]
set RESULT $response
set CODE 0
test agent-chat-15 {[agent_http_status $RESULT] eq {200}}
test agent-chat-16 {[string first {value="codex"} $RESULT]>=0}
test agent-chat-17 {[string first {value="test-chat-model"} $RESULT]>=0}
test agent-chat-18 {[string first {{progress}} $RESULT]>=0}
test agent-chat-19 {[string first {{tool}} $RESULT]>=0}
test agent-chat-20 {[string first {System:} $RESULT]>=0}
test agent-chat-20a {[string first {[codex / test-chat-model | reply]} $RESULT]>=0}
test agent-chat-21 {[string first {meta={&quot;stage&quot;:&quot;context&quot;,&quot;enabled&quot;:true}} $RESULT]>=0}
test agent-chat-22 {[string first {meta={&quot;tool&quot;:&quot;chat-backend&quot;,&quot;provider&quot;:&quot;codex&quot;}} $RESULT]>=0}
test agent-chat-23 {[string first {meta={&quot;stage&quot;:&quot;backend&quot;,&quot;status&quot;:&quot;running&quot;}} $RESULT]>=0}
